# ─────────────────────────────────────────────────────────────────────────────
# HeyPico Maps LLM — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git (it's in .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# ── Google Maps API ───────────────────────────────────────────────────────────
# Get your API key: https://console.cloud.google.com/
# Required APIs: Places API (New), Directions API, Geocoding API, Maps Embed API, Maps Static API
# IMPORTANT: Restrict your key to specific APIs and allowed HTTP referrers/IPs
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ── Backend Internal Security ─────────────────────────────────────────────────
# This key is used by Open WebUI Tools to authenticate with the backend API.
# Generate a random string: python -c "import secrets; print(secrets.token_hex(32))"
BACKEND_API_KEY=change_this_to_a_random_secret_key

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_DAY=1000

# ── Cache (Redis) ─────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
CACHE_TTL_PLACES_SECONDS=3600
CACHE_TTL_DIRECTIONS_SECONDS=1800
CACHE_TTL_GEOCODE_SECONDS=86400

# ── Open WebUI ────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBUI_SECRET_KEY=change_this_to_a_random_secret_key
ADMIN_EMAIL=admin@heypico.ai
ADMIN_PASSWORD=heypico2026

# ── Ollama ─────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
DEFAULT_MODEL=qwen2.5:7b

# ── Backend Config ─────────────────────────────────────────────────────────────
# URL that Open WebUI Tools use to call the backend
# When running in Docker: use the service name
# When running locally: use http://localhost:8000
BACKEND_URL=http://backend:8000
DEBUG=false
